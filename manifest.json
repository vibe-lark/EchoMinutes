{
  "manifest_version": 3,
  "name": "小宇宙/Bilibili转存飞书妙记",
  "version": "1.6",
  "description": "读取小宇宙页面音频或Bilibili视频，并一键上传到飞书妙记",
  "permissions": [
    "storage",
    "webRequest",
    "cookies",
    "scripting",
    "declarativeNetRequest",
    "activeTab"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaoyuzhoufm.com/*",
        "https://xiaoyuzhoufm.com/*"
      ],
      "js": [
        "src/content/analytics.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://bilibili.com/video/*"
      ],
      "js": [
        "browser-sdk/browser-muxer.js",
        "browser-sdk/bilibili-sdk.js",
        "src/content/analytics.js",
        "src/content/bilibili.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background/main.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "icons": {
    "16": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "images/logo.png",
        "images/Crobat.png",
        "images/Crobat.svg",
        "images/icon16.png",
        "images/icon48.png",
        "images/icon128.png",
        "vendor/byted-tea-sdk/index.min.js",
        "browser-sdk/browser-muxer.js",
        "browser-sdk/bilibili-sdk.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
